{%- comment -%}
  Shared Diode Collab app download content (terms, platform buttons, other platforms list, notes).
  include.standalone: when true, used on /download page (e.g. "See below" for Network); when false, used in popup ("Download Center" link).
{%- endcomment -%}
{%- assign standalone = include.standalone | default: false -%}

<div class="download-popup">
    <div class="download-popup__buttons detect-os">
        <a class="btn btn-primary os macos-legacy" href="{{ site.download.app.macos-legacy }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">DOWNLOAD FOR MacOS (Legacy ARM / Intel)</a>
        <a class="btn btn-primary os macos-arm hide" href="{{ site.download.app.macos-arm }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">DOWNLOAD FOR MacOS (Apple Silicon)</a>
        <a class="btn btn-primary os macos-intel hide" href="{{ site.download.app.macos-intel }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">DOWNLOAD FOR MacOS (Intel)</a>
        <a class="btn btn-primary os windows hide" href="{{ site.download.app.windows }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">DOWNLOAD FOR Windows (64-bit)</a>
        <a class="btn btn-primary os linux hide" href="{{ site.download.app.linux }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">DOWNLOAD FOR Linux (64-bit)</a>
        <a class="btn btn-primary os raspberry-pi hide" href="{{ site.download.app.raspberry-pi }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">DOWNLOAD FOR Raspberry Pi / ARM 32bit</a>
        <a class="btn btn-primary os raspberry-pi-64 hide" href="{{ site.download.app.raspberry-pi-64 }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">DOWNLOAD FOR Raspberry Pi / ARM 64bit</a>
        <a class="btn btn-primary os ios hide" href="{{ site.download.app.ios }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">GET FOR iOS</a>
        <a class="btn btn-primary os android hide" href="{{ site.download.app.android }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">GET FOR Android</a>
    </div>

    <p class="download-popup__other-title">Or choose another Platform:</p>
    <ul class="download-popup__other">
        <li><a href="{{ site.download.app.macos-arm }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">MacOS (Apple Silicon)</a></li>
        <li><a href="{{ site.download.app.macos-intel }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">MacOS (Intel - TAHOE BETA ONLY)</a></li>
        <li><a href="{{ site.download.app.macos-legacy }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">MacOS (Legacy ARM / Intel)</a></li>
        <li><a href="{{ site.download.app.windows }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">Windows (64-bit)</a></li>
        <li><a href="{{ site.download.app.linux }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">Linux (64-bit)</a><code class="sha">{{ site.download.app.linux-checksum }}</code></li>
        <li><a href="{{ site.download.app.raspberry-pi }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">Raspberry Pi / ARM 32bit</a><code class="sha">{{ site.download.app.raspberry-pi-checksum }}</code></li>
        <li><a href="{{ site.download.app.raspberry-pi-64 }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">Raspberry Pi / ARM 64bit</a><code class="sha">{{ site.download.app.raspberry-pi-64-checksum }}</code></li>
        <li><a href="{{ site.download.app.ios }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">iOS</a></li>
        <li><a href="{{ site.download.app.android }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">Android (Play Store)</a></li>
        <li><a href="{{ site.download.app.android-apk }}" target="_blank" rel="noopener" onclick="ThankYouRedirect('{{ site.links.thanks.url }}')">Android APK</a><code class="sha">{{ site.download.app.android-apk-checksum }}</code></li>
    </ul>
    <p class="download-popup__note">MacOS + Windows builds are signed/notarized. For Linux builds please compare the SHA-1 checksum above with the file downloaded for validation.</p>
    <br/>
    <header class="download-app-content__header">
        <p>By downloading Diode Collab you accept the <a href="https://diode.io/terms" target="_blank" rel="noopener">terms</a> and our <a href="https://diode.io/privacy-policy" target="_blank" rel="noopener">privacy policy</a>.</p>
    </header>
    <br/>
    <p class="download-popup__note"><strong>Developers:</strong> Go to the <a class="close-popup" href="https://diode.io/download/#cli" target="_blank" rel="noopener">Diode Download Center</a> for the ZTNA Console, CLI, Private AI, or Network Node.</p>
</div>
