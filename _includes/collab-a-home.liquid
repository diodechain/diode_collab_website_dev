{%- assign hero = page.collab_a_hero | default: page.hero -%}
{%- assign nav_links = page.collab_a_nav | default: site.collab_a_nav | default: nil -%}
{%- assign footer = page.collab_a_footer | default: site.collab_a_footer | default: nil -%}

{%- comment -%} Decorative background assets (wrapped so markdown doesn't add &lt;p&gt;) {%- endcomment -%}
<div class="collab-a-bg" aria-hidden="true">
<img src="{{ 'home/diode-mesh.png' | prepend: site.path.images | relative_url }}" alt="" class="diode-mesh" />
<img src="{{ 'icons/diode-collab-white.png' | prepend: site.path.images | relative_url }}" alt="" class="collab-a-img2 collab-a-logo-white" />
<img src="{{ 'icons/diode-collab-white.png' | prepend: site.path.images | relative_url }}" alt="" class="collab-a-img2 collab-a-logo-orange" />
</div>

<div class="collab-a-row1">
	<div class="collab-a-col-left">
		<object data="{{ 'home/phone-outline.svg' | prepend: site.path.images | relative_url }}" class="collab-a-graphic2" type="image/svg+xml" aria-hidden="true"></object>
		<div class="collab-a-line-top"></div>
		<img src="{{ 'home/phone-screen.png' | prepend: site.path.images | relative_url }}" alt="" class="collab-a-img collab-a-mobile-chat" />
	</div>

	<div class="collab-a-col-right">
		<h1 class="collab-a-title">{{ hero.heading | default: hero.title | default: "Private Team Collaboration" }}</h1>
		<div class="collab-a-subtitle">
			{{ hero.subheading | default: hero.subtitle | default: "**Team messaging.  Organized files.  VPN.**

No data, accounts, or PII on a server.

Everything your team needs to stay connected privately, no matter where they are in the world." | markdownify }}
		</div>
		<a href="{{ hero.btn_url | default: '#download-app' }}" class="collab-a-btn-download popup-open">{{ hero.btn_download | default: "DOWNLOAD" }}</a>
		<div class="collab-a-line"></div>
		<div class="collab-a-store-badges">
			<img src="{{ 'home/playstore-badge.png' | prepend: site.path.images | relative_url }}" alt="Get it on Google Play" class="collab-a-img collab-a-playstore-badge" />
			<img src="{{ 'home/appstore-badge.png' | prepend: site.path.images | relative_url }}" alt="Download on the App Store" class="collab-a-img collab-a-appstore-badge" />
		</div>
	</div>
</div>

<div class="footer-menu">
	<div class="home-page-menu">
		{%- if nav_links -%}
			{%- for link in nav_links -%}
				<p class="collab-a-text-a"><a href="{{ link.url | relative_url }}">{{ link.label }}</a></p>
			{%- endfor -%}
		{%- else -%}
			<p class="collab-a-text-a"><a href="{{ '/pricing/' | relative_url }}">Pricing</a></p>
			<p class="collab-a-text-a"><a href="{{ '/blog/' | relative_url }}">Stories</a></p>
			<p class="collab-a-text-a"><a href="https://docs.diode.io" target="_blank" rel="noopener">Docs</a></p>
			<p class="collab-a-text-a"><a href="{{ '/support.html' | relative_url }}">Support</a></p>
			<p class="collab-a-text-a"><a href="{{ '/about/' | relative_url }}">More about Diode</a></p>
		{%- endif -%}
	</div>
	<ul class="collab-a-social-icons">
		{%- if site.social.youtube -%}
		<li><a href="{{ site.social.youtube }}" aria-label="YouTube" target="_blank" rel="noopener"><svg xmlns="http://www.w3.org/2000/svg" width="27" height="19" viewBox="-1 -6 30 30" fill="none"><path fill="white" d="M25.71 2.876A3.289 3.289 0 0 0 23.395.562C21.34 0 13.125 0 13.125 0S4.908 0 2.855.54A3.355 3.355 0 0 0 .54 2.877C0 4.93 0 9.19 0 9.19s0 4.28.54 6.313a3.29 3.29 0 0 0 2.314 2.314c2.076.562 10.271.562 10.271.562s8.216 0 10.27-.54a3.289 3.289 0 0 0 2.314-2.314c.54-2.054.54-6.314.54-6.314s.023-4.281-.54-6.335ZM10.508 13.125v-7.87L17.34 9.19l-6.832 3.935Z"/></svg></a></li>
		{% endif %}
		{%- if site.social.discord -%}
		<li><a href="{{ site.social.discord }}" aria-label="Discord" target="_blank" rel="noopener"><svg xmlns="http://www.w3.org/2000/svg" width="29" height="24" viewBox="0 0 127.14 96.36" fill="none"><path fill="white" d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/></svg></a></li>
		{% endif %}
		{%- if site.social.twitter -%}
		<li><a href="{{ site.social.twitter }}" aria-label="Twitter" target="_blank" rel="noopener"><svg xmlns="http://www.w3.org/2000/svg" width="29" height="23" viewBox="-1 -4 30 30" fill="none"><path fill="white" d="M28.249 2.693c-1.041.457-2.15.76-3.307.907A5.708 5.708 0 0 0 27.466.427a11.472 11.472 0 0 1-3.64 1.39 5.738 5.738 0 0 0-9.93 3.925c0 .455.039.892.133 1.309C9.258 6.818 5.035 4.53 2.2 1.046a5.78 5.78 0 0 0-.786 2.902 5.749 5.749 0 0 0 2.55 4.77 5.669 5.669 0 0 1-2.594-.707v.064c0 2.789 1.99 5.106 4.599 5.64a5.731 5.731 0 0 1-1.505.189c-.367 0-.738-.021-1.087-.098.744 2.273 2.855 3.944 5.364 3.999a11.534 11.534 0 0 1-7.117 2.448c-.471 0-.922-.021-1.374-.079a16.16 16.16 0 0 0 8.806 2.576c10.563 0 16.338-8.75 16.338-16.334 0-.254-.009-.5-.021-.743a11.45 11.45 0 0 0 2.877-2.98Z"/></svg></a></li>
		{% endif %}
		{%- if site.social.github -%}
		<li><a href="{{ site.social.github }}" aria-label="GitHub" target="_blank" rel="noopener"><svg xmlns="http://www.w3.org/2000/svg" width="30" height="28" viewBox="0 -1 30 30" fill="none"><path fill="white" d="M14.857 0C6.787 0 .25 6.428.25 14.355c0 6.344 4.185 11.724 9.989 13.62.73.135.998-.309.998-.69 0-.34-.012-1.244-.018-2.44-4.064.865-4.921-1.927-4.921-1.927-.665-1.657-1.625-2.1-1.625-2.1-1.324-.89.102-.871.102-.871 1.467.1 2.238 1.479 2.238 1.479 1.302 2.195 3.42 1.56 4.254 1.194.132-.929.508-1.56.925-1.92-3.244-.359-6.654-1.593-6.654-7.093 0-1.567.566-2.848 1.504-3.852-.165-.363-.658-1.823.128-3.8 0 0 1.223-.384 4.017 1.472a14.262 14.262 0 0 1 3.652-.484c1.242.007 2.484.165 3.652.484 2.776-1.856 4-1.472 4-1.472.784 1.977.291 3.437.145 3.8.932 1.004 1.498 2.285 1.498 3.852 0 5.514-3.415 6.728-6.665 7.081.51.431.986 1.311.986 2.656 0 1.921-.019 3.465-.019 3.931 0 .376.256.826 1.005.682 5.844-1.884 10.026-7.268 10.026-13.602C29.466 6.428 22.925 0 14.857 0Z"/></svg></a></li>
		{% endif %}
	</ul>
</div>

<div class="footer-credits">
	{%- if footer -%}
		<p class="reserved-blurb">{{ footer.line1 | default: footer }}</p>
		<p class="compliance-blurb">{{ footer.line2 }}</p>
	{%- else -%}
		<p class="reserved-blurb">
			<span class="reserved-blurb-line1">DIODE © {{ site.time | date: "%Y" }}, All Rights Reserved</span>
			<span class="reserved-blurb-line2"><a href="{{ '/terms/' | relative_url }}">Terms</a> | <a href="{{ '/privacy-policy/' | relative_url }}">Privacy Policy</a></span>
		</p>
		<p class="compliance-blurb">ISO 27001, SOC-2, GDPR, HIPAA, etc.</p>
	{%- endif -%}
</div>
