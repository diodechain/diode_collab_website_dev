<head prefix="og: http://ogp.me/ns# fb: http://ogp.me/ns/fb#">
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="index, follow">

    <!-- SEO -->
    {%- seo -%}

    <!-- Hreflang for multilingual pages -->
    {%- if page.hreflang_alt -%}
    <link rel="alternate" hreflang="{{ page.lang | default: 'en' }}" href="{{ page.url | absolute_url }}" />
    {%- for alt in page.hreflang_alt -%}
    <link rel="alternate" hreflang="{{ alt[0] }}" href="{{ alt[1] | absolute_url }}" />
    {%- endfor -%}
    {%- endif -%}

    <!-- Stylesheet -->
    <link href="{{ "style.css" | prepend: site.path.styles | relative_url }}" rel="stylesheet">
    {%- if page.layout == 'page-collab-a' -%}
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400&family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700&display=swap" rel="stylesheet">
    {%- endif -%}

    <!-- Javascript -->
    <script src="{{ "swiper.js" | prepend: site.path.scripts | relative_url }}" defer></script>
    <script src="{{ "aos.js" | prepend: site.path.scripts | relative_url }}" defer></script>
    <script src="{{ "script.js" | prepend: site.path.scripts | relative_url }}" defer></script>

    <!-- Favicon -->
    <link rel="apple-touch-icon" sizes="180x180" href="{{ "apple-touch-icon.png" | prepend: site.path.favicon | relative_url }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ "favicon-32x32.png" | prepend: site.path.favicon | relative_url }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ "favicon-16x16.png" | prepend: site.path.favicon | relative_url }}">
    <link rel="manifest" href="{{ "site.webmanifest" | prepend: site.path.favicon | relative_url }}">
    <link rel="mask-icon" href="{{ "safari-pinned-tab.svg" | prepend: site.path.favicon | relative_url }}" color="#f15d2f">
    <link rel="shortcut icon" href="{{ "favicon.ico" | prepend: site.path.favicon | relative_url }}">
    <meta name="msapplication-config" content="{{ "browserconfig.xml" | prepend: site.path.favicon | relative_url }}">
    <meta name="msapplication-TileColor" content="#ffffff">
    <meta name="theme-color" content="#ffffff">


    <!-- Google Tag Manager -->
    <script>(function (w, d, s, l, i) {w[l] = w[l] || [];w[l].push({'gtm.start': new Date().getTime(), event: 'gtm.js'});var f = d.getElementsByTagName(s)[0], j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : '';j.async = true;j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;f.parentNode.insertBefore(j, f);})(window, document, 'script', 'dataLayer', 'GTM-59C3BGK');</script>
    <!-- End Google Tag Manager -->

    <!-- Ahref Analytics -->
    <script src="https://analytics.ahrefs.com/analytics.js" data-key="sgT97oIbwhvXHN0ggFOhWw" async></script>
</head>
